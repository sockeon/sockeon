{
    "name": "sockeon/sockeon",
    "description": "Framework-agnostic PHP WebSocket and HTTP server library with attribute-based routing and support for namespaces and rooms.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Sockeon\\Sockeon\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "xentixar",
            "email": "xentixar@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-openssl": "*",
        "ext-sockets": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "keywords": [
        "websocket",
        "socket",
        "http",
        "https",
        "realtime",
        "event-driven",
        "php",
        "laravel",
        "symfony",
        "framework-agnostic"
    ],
    "require-dev": {
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "suggest": {
        "ext-openswoole": "Required for engine=swoole high-concurrency mode",
        "ext-redis": "Required for scale.publisher=redis or scale.registry=redis multi-node mode"
    },
    "config": {
        "platform": {
            "php": "8.3.0"
        },
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "bin": [
        "bin/sockeon-upgrade"
    ]
}
